{
  description = "My dotfiles";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs?ref=nixos-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    nixvim = {
      url = "github:nix-community/nixvim";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    sops-nix = {
      url = "github:Mic92/sops-nix";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    nix-search-tv.url = "github:3timeslazy/nix-search-tv";
    npc = {
      # A CLI tool to access the history of Nixpkgs channels.
      url = "github:samestep/npc";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs = {
    self,
    nixpkgs,
    home-manager,
    nixvim,
    sops-nix,
    nix-search-tv,
    npc,
    ...
  } @ inputs:
    let
      systems = [ "x86_64-linux" "aarch64-linux" ];
      pkgs = nixpkgs.legacyPackages.${system};
      makeModules = system: [
        ./host/configuration.nix
        ./modules/programs/cli/direnv
        ./modules/programs/editor/nixvim
        ./modules/services/virtual/containerd
        ./modules/programs/cli/sops-nix
        home-manager.nixosModules.home-manager {
          home-manager = {
            useGlobalPkgs = true;
            useUserPackages = true;
            extraSpecialArgs = { inherit self inputs; };
            users.${settings.username} = {
              imports = [
                ./modules/home-manager/home.nix
                ./modules/programs/cli/bash
                ./modules/programs/cli/git
                ./modules/programs/cli/tmux
                ./modules/programs/cli/fzf
                ./modules/programs/cli/television
                ./modules/programs/cli/nix-search-tv
                ./modules/programs/cli/npc
              ];
            };
          };
        }
      ];
    in
    {
      devShells = builtins.listToAttrs (map (system:
        {
          name = system;
          value = let pkgs = import nixpkgs { inherit system; }; in
          {
            default = pkgs.mkShellNoCC {
              NIX_CONFIG = "experimental-features = nix-command flakes";
            };
          };
        }
      ) systems);

      nixosConfigurations = let
        thisSystem = if builtins.hasAttr "currentSystem" builtins
                     then builtins.currentSystem
                     else "x86_64-linux";
      in
        builtins.listToAttrs (
          [
            {
              name = settings.hostname;
              value = nixpkgs.lib.nixosSystem {
                system = thisSystem;
                modules = makeModules thisSystem;
                specialArgs = { inherit self inputs settings; };
              };
            }
          ] ++ map (system: {
            name = "nixos-${system}";
            value = nixpkgs.lib.nixosSystem {
              inherit system;
              modules = makeModules system;
              specialArgs = { inherit self inputs settings; };
            };
          }) systems
        );
    };
}
